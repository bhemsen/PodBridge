<?xml version="1.0" encoding="utf-8"?>

<!--
  MSIX package manifest for PodBridge.App (Phase 5 packaging).

  Identity below is a THROWAWAY self-signed identity for the CI artifact and the
  GitHub-Releases manual fallback ONLY. The Store-matching Identity/Name and
  Publisher (and the msstore product id) are Partner-Center-derived and applied
  later at Store association (#38); they are NOT invented here.
  The signing certificate Subject MUST equal the Publisher string below
  (docs/research/msix-packaging.md, source 6) - the CI workflow generates a
  self-signed cert with exactly this Subject.

  Coined product name is "PodBridge" (constitution: no "Apple"/"AirPods" in the
  name, no Apple logo). "for AirPods on Windows" is a descriptor only.
  EntryPoint="Windows.FullTrustApplication" runs the WPF app as a normal
  unelevated Win32 desktop app; asInvoker is preserved by app.manifest (no
  elevation at run time). No kernel driver is part of this package (app-only).
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap5="http://schemas.microsoft.com/appx/manifest/uap/windows10/5"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap rescap">

  <Identity
    Name="PodBridgeContributors.PodBridge"
    Publisher="CN=PodBridge (Self-Signed CI)"
    Version="0.1.0.0" />

  <Properties>
    <DisplayName>PodBridge</DisplayName>
    <PublisherDisplayName>PodBridge contributors</PublisherDisplayName>
    <Logo>Images\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.22621.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application Id="PodBridge" Executable="PodBridge.App.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="PodBridge"
        Description="Open-source companion for AirPods on Windows: battery, auto play/pause, codec transparency and a microphone-profile policy. Not affiliated with Apple."
        BackgroundColor="transparent"
        Square150x150Logo="Images\Square150x150Logo.png"
        Square44x44Logo="Images\Square44x44Logo.png">
        <uap:DefaultTile ShortName="PodBridge" />
      </uap:VisualElements>
      <Extensions>
        <!--
          Opt-in auto-start-at-login (#35). Enabled="false" is the load-bearing
          default: auto-start is OFF until the user turns it on from the About
          surface (StartupTaskToggle over the StartupTask WinRT API). TaskId MUST
          equal StartupTaskToggle.TaskId. A packaged desktop app enables silently
          (no consent dialog); the user's Settings/Task-Manager disable still wins.

          Executable is "PodBridge.App\PodBridge.App.exe" (subfolder), NOT the
          bare "PodBridge.App.exe" the <Application> element carries. The .wapproj
          publishes the ProjectReference into a project-named subfolder and, at
          build time, rewrites ONLY the <Application>/@Executable to that resolved
          path; it does not touch this custom Extension. MakeAppx validates the
          Extension's Executable against the actual package layout, so it must be
          the resolved subfolder path or packaging fails with 0x80080204.
        -->
        <uap5:Extension
          Category="windows.startupTask"
          Executable="PodBridge.App\PodBridge.App.exe"
          EntryPoint="Windows.FullTrustApplication">
          <uap5:StartupTask
            TaskId="PodBridgeStartup"
            Enabled="false"
            DisplayName="PodBridge" />
        </uap5:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <!-- Minimal capability set. runFullTrust is the mandatory capability for a
         packaged Win32/desktop app; it means "normal desktop app" (full trust),
         NOT elevation/admin - the app still runs asInvoker. bluetooth is
         required for the Tier-1 WinRT BLE advertisement watcher (the core
         battery / in-ear feature). No elevated or privacy-broad capabilities. -->
    <rescap:Capability Name="runFullTrust" />
    <DeviceCapability Name="bluetooth" />
  </Capabilities>
</Package>
