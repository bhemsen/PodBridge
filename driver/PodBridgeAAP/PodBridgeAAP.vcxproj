<?xml version="1.0" encoding="utf-8"?>
<!--
  PodBridge AAP KMDF L2CAP bridge (optional Tier-2 driver).

  Builds with the WDK delivered as NuGet packages (Microsoft.Windows.WDK.x64 +
  Microsoft.Windows.SDK.CPP.x64), so it compiles headlessly on windows-latest CI
  without an interactive WDK installer (research #40 (e)). x64 only. The .NET
  Verify (build/verify.ps1) does NOT touch this project; it is intentionally
  outside PodBridge.slnx.

  Restore + build:
    msbuild PodBridgeAAP.vcxproj /t:restore
    msbuild PodBridgeAAP.vcxproj /p:Configuration=Release /p:Platform=x64
-->
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>
  <PropertyGroup Label="Globals">
    <ProjectGuid>{09251AFB-4981-41A3-B151-DDEE81990CF5}</ProjectGuid>
    <RootNamespace>PodBridgeAAP</RootNamespace>
    <MinimumVisualStudioVersion>17.0</MinimumVisualStudioVersion>
    <TargetVersion>Windows10</TargetVersion>
    <!-- Desktop (not Universal): PodBridge targets Windows 11 desktop, and this
         skips the Universal ApiValidator post-build step so the compile-only CI
         gate does not fail on non-UniversalDDI APIs. -->
    <DriverTargetPlatform>Desktop</DriverTargetPlatform>
    <WindowsTargetPlatformVersion>10.0.26100.0</WindowsTargetPlatformVersion>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <PropertyGroup Label="Configuration">
    <ConfigurationType>Driver</ConfigurationType>
    <DriverType>KMDF</DriverType>
    <PlatformToolset>WindowsKernelModeDriver10.0</PlatformToolset>
    <!-- Off so the build does not require the Spectre-mitigated libraries to be
         present on the runner; this is a compile-only regression gate, not a
         shipped/signed binary. -->
    <SpectreMitigation>false</SpectreMitigation>
  </PropertyGroup>
  <PropertyGroup Label="Configuration" Condition="'$(Configuration)'=='Debug'">
    <UseDebugLibraries>true</UseDebugLibraries>
  </PropertyGroup>
  <PropertyGroup Label="Configuration" Condition="'$(Configuration)'=='Release'">
    <UseDebugLibraries>false</UseDebugLibraries>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <ItemDefinitionGroup>
    <ClCompile>
      <WarningLevel>Level4</WarningLevel>
      <!-- Compile-only CI gate: do not fail the build on WDK style warnings. -->
      <TreatWarningAsError>false</TreatWarningAsError>
    </ClCompile>
  </ItemDefinitionGroup>
  <ItemGroup>
    <ClCompile Include="Driver.c" />
    <ClCompile Include="Device.c" />
    <ClCompile Include="Queue.c" />
    <ClCompile Include="L2cap.c" />
  </ItemGroup>
  <ItemGroup>
    <ClInclude Include="Driver.h" />
    <ClInclude Include="Public.h" />
  </ItemGroup>
  <ItemGroup>
    <None Include="PodBridgeAAP.inf" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Windows.WDK.x64" Version="10.0.26100.6584" />
    <PackageReference Include="Microsoft.Windows.SDK.CPP.x64" Version="10.0.26100.6584" />
  </ItemGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>
