{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": ["Bash", "WebFetch", "WebSearch"],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd*)",
      "Bash(git branch -D *)",
      "Bash(bcdedit*)"
    ]
  }
}
