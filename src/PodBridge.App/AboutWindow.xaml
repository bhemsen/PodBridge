<Window x:Class="PodBridge.App.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About PodBridge"
        Width="540" Height="690"
        MinWidth="440" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        ResizeMode="CanResize">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header: coined name (no Apple logo), descriptor, version, tagline. -->
    <StackPanel Grid.Row="0" Margin="0,0,0,12">
      <TextBlock Text="{Binding ProductName}" FontSize="26" FontWeight="SemiBold" />
      <TextBlock Text="{Binding Descriptor}" FontSize="14" Opacity="0.8" Margin="0,2,0,0" />
      <TextBlock Text="{Binding VersionLine}" FontSize="12" Opacity="0.7" Margin="0,6,0,0" />
      <TextBlock Text="{Binding Tagline}" TextWrapping="Wrap" Margin="0,6,0,0" />
    </StackPanel>

    <!-- Mandatory not-affiliated / trademark disclaimer. -->
    <Border Grid.Row="1" BorderThickness="1" BorderBrush="#33888888"
            CornerRadius="4" Padding="10" Margin="0,0,0,10">
      <TextBlock Text="{Binding Disclaimer}" TextWrapping="Wrap" />
    </Border>

    <!-- Honest audio/mic note (never claims Apple-parity sound). -->
    <TextBlock Grid.Row="2" Text="{Binding AudioNote}" TextWrapping="Wrap"
               Opacity="0.9" Margin="0,0,0,10" />

    <!-- License line. -->
    <TextBlock Grid.Row="3" Text="{Binding LicenseLine}" TextWrapping="Wrap"
               Margin="0,0,0,6" />

    <!-- Opt-in auto-start-at-login (default OFF). Reflects and sets the MSIX
         StartupTask state via IStartupToggle; the hint appears only when Windows
         (the user or policy) has blocked it, which the app cannot override. -->
    <StackPanel Grid.Row="4" Margin="0,0,0,12">
      <CheckBox x:Name="AutoStartCheckBox"
                Content="Start PodBridge automatically when I sign in"
                Checked="OnAutoStartChecked" Unchecked="OnAutoStartUnchecked" />
      <TextBlock x:Name="AutoStartHint" Visibility="Collapsed"
                 Text="Auto-start is turned off in Windows Settings or Task Manager; change it there."
                 TextWrapping="Wrap" FontSize="11" Opacity="0.7" Margin="24,4,0,0" />
    </StackPanel>

    <!-- Documentation + project links. -->
    <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,12">
      <TextBlock>
        <Hyperlink NavigateUri="{Binding DocsUri}" RequestNavigate="OnRequestNavigate">
          User documentation
        </Hyperlink>
      </TextBlock>
      <TextBlock Text="   ·   " Opacity="0.6" />
      <TextBlock>
        <Hyperlink NavigateUri="{Binding ProjectUri}" RequestNavigate="OnRequestNavigate">
          Project page
        </Hyperlink>
      </TextBlock>
    </StackPanel>

    <!-- Third-party notices heading. -->
    <TextBlock Grid.Row="6" Text="Third-party notices" FontWeight="SemiBold"
               Margin="0,0,0,4" />

    <!-- Third-party notices body (from THIRD-PARTY-NOTICES.md), scrollable. -->
    <Border Grid.Row="7" BorderThickness="1" BorderBrush="#33888888" CornerRadius="4">
      <TextBox Text="{Binding ThirdPartyNotices, Mode=OneWay}"
               IsReadOnly="True" BorderThickness="0" Background="Transparent"
               FontFamily="Consolas" FontSize="11"
               TextWrapping="Wrap" AcceptsReturn="True"
               VerticalScrollBarVisibility="Auto"
               HorizontalScrollBarVisibility="Auto" Padding="8" />
    </Border>

    <!-- Close. -->
    <Button Grid.Row="8" Content="Close" IsCancel="True" IsDefault="True"
            HorizontalAlignment="Right" MinWidth="88" Padding="12,4"
            Margin="0,12,0,0" Click="OnClose" />
  </Grid>
</Window>
