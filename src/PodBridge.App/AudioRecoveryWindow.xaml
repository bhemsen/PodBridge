<Window x:Class="PodBridge.App.AudioRecoveryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Audio recovery guide"
        Width="480" Height="500"
        MinWidth="400" MinHeight="440"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        ResizeMode="CanResize">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Heading. -->
    <TextBlock x:Name="HeaderText" Grid.Row="0" FontSize="20" FontWeight="SemiBold"
               TextWrapping="Wrap" Margin="0,0,0,10" />

    <!-- Honest root-cause explanation: a Windows-level failure, not a PodBridge bug,
         which PodBridge cannot fix directly (no admin, no driver by default). -->
    <Border Grid.Row="1" BorderThickness="1" BorderBrush="#33888888" CornerRadius="4"
            Padding="10" Margin="0,0,0,16">
      <TextBlock x:Name="ExplanationText" TextWrapping="Wrap" />
    </Border>

    <!-- Step 1: restart the PC (the simplest fix). -->
    <StackPanel Grid.Row="2" Margin="0,0,0,12">
      <TextBlock x:Name="Step1TitleText" FontWeight="SemiBold" TextWrapping="Wrap" />
      <TextBlock x:Name="Step1BodyText" TextWrapping="Wrap" Margin="0,2,0,0" Opacity="0.9" />
    </StackPanel>

    <!-- Step 2: restart Windows Audio + Windows Audio Endpoint Builder via services.msc. -->
    <StackPanel Grid.Row="3" Margin="0,0,0,8">
      <TextBlock x:Name="Step2TitleText" FontWeight="SemiBold" TextWrapping="Wrap" />
      <TextBlock x:Name="Step2BodyText" TextWrapping="Wrap" Margin="0,2,0,0" Opacity="0.9" />
    </StackPanel>

    <!-- Convenience button: shell-launches services.msc. PodBridge requests no
         elevation itself — Windows prompts for admin to restart a service there. -->
    <Button x:Name="OpenServicesButton" Grid.Row="4" HorizontalAlignment="Left"
            Padding="12,4" Margin="0,0,0,16" Click="OnOpenServices" />

    <!-- Step 3 / tip: shut down instead of sleep/hibernate between long idle periods. -->
    <StackPanel Grid.Row="5" Margin="0,0,0,10">
      <TextBlock x:Name="Step3TitleText" FontWeight="SemiBold" TextWrapping="Wrap" />
      <TextBlock x:Name="Step3BodyText" TextWrapping="Wrap" Margin="0,2,0,0" Opacity="0.9" />
    </StackPanel>

    <!-- Close. -->
    <Button Grid.Row="7" Content="Close" IsCancel="True" IsDefault="True"
            HorizontalAlignment="Right" MinWidth="88" Padding="12,4"
            Margin="0,12,0,0" Click="OnClose" />
  </Grid>
</Window>
